# -----------------------------------------------------------------------------
# Doctor-Meds Backend ó Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env ó it is in .gitignore.
# -----------------------------------------------------------------------------

# Server
PORT=10000
NODE_ENV=development

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# JWT secret ó use a long random string (min 32 chars)
JWT_SECRET=

# Deployed frontend URL (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173
